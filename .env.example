# Copy to .env.local and fill in real values. .env.local is git-ignored.

# Supabase — client-safe (anon key is designed to be public behind RLS)
# Next.js reads the NEXT_PUBLIC_* names. If your Vercel project still uses
# legacy VITE_* names, next.config.js maps them into these public variables.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Aloware — SERVER-ONLY. Never prefix with NEXT_PUBLIC_.
# Used only by app/api/sms-signup to forward opted-in contacts.
ALOWARE_API_BASE_URL=https://app.aloware.io/api/v1
ALOWARE_API_TOKEN=
ALOWARE_DIALER_URL=https://app.aloware.com

# Optional Aloware associations. Leave blank to skip.
ALOWARE_TAG_ID=
ALOWARE_LINE_ID=
ALOWARE_RING_GROUP_ID=

# Google Analytics (already referenced in app/layout.tsx)
NEXT_PUBLIC_GA_ID=
