# Copy to .env.local and fill in real values. .env.local is git-ignored.

# Supabase — client-safe (anon key is designed to be public behind RLS).
# This app reads only the VITE_* names.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Aloware — SERVER-ONLY. Used only by app/api/sms-signup to forward
# opted-in contacts. The server accepts either ALOWARE_* or VITE_ALOWARE_*.
ALOWARE_API_TOKEN=
VITE_ALOWARE_API_TOKEN=
ALOWARE_DIALER_URL=https://app.aloware.com
VITE_ALOWARE_DIALER_URL=https://app.aloware.com
